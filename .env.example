# Copier vers .env et renseigner les valeurs (ne pas committer .env).

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Secret partagé app mobile ↔ API (header Authorization: Bearer … sur certains endpoints).
# Pas le JWT utilisateur Supabase. En prod : longue valeur aléatoire.
# Si vide, le code utilise le défaut de dev "dev-internal-bearer".
INTERNAL_API_BEARER=

# Hachage des secrets QR commandes client (confirm-receipt). En prod : longue chaîne aléatoire.
CUSTOMER_SALE_QR_PEPPER=

# Liens de partage Flutter / App Links.
# Exemple prod : SHARE_BASE_URL=https://share.emall.app
SHARE_BASE_URL=http://localhost:8000
SHARE_APP_SCHEME=emall
SHARE_ANDROID_PACKAGE_NAME=example.e_mall
SHARE_ANDROID_SHA256_CERT_FINGERPRINTS=90:F4:59:3F:51:18:B7:99:F7:8D:EA:E9:76:86:BB:F4:01:C5:F7:13:12:3A:A6:CD:44:DC:1A:BE:6E:C5:8B:61
SHARE_IOS_APP_ID=
SHARE_PLAY_STORE_URL=
SHARE_APP_STORE_URL=

# Traitement video des posts.
# Optionnel si ffmpeg/ffprobe sont deja dans le PATH.
FFMPEG_BINARY=
FFPROBE_BINARY=
