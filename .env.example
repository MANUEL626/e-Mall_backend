# Copier vers .env et renseigner les valeurs (ne pas committer .env).

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Secret partagé app mobile ↔ API (header Authorization: Bearer … sur certains endpoints).
# Pas le JWT utilisateur Supabase. En prod : longue valeur aléatoire.
# Si vide, le code utilise le défaut de dev "dev-internal-bearer".
INTERNAL_API_BEARER=

# Hachage des secrets QR commandes client (confirm-receipt). En prod : longue chaîne aléatoire.
CUSTOMER_SALE_QR_PEPPER=

# Liens de partage Flutter / App Links.
# Exemple prod : SHARE_BASE_URL=https://share.emall.app
SHARE_BASE_URL=http://localhost:8000
SHARE_APP_SCHEME=emall
SHARE_ANDROID_PACKAGE_NAME=example.e_mall
SHARE_ANDROID_SHA256_CERT_FINGERPRINTS=90:F4:59:3F:51:18:B7:99:F7:8D:EA:E9:76:86:BB:F4:01:C5:F7:13:12:3A:A6:CD:44:DC:1A:BE:6E:C5:8B:61
SHARE_IOS_APP_ID=
SHARE_PLAY_STORE_URL=
SHARE_APP_STORE_URL=

# Traitement video des posts.
# Optionnel si ffmpeg/ffprobe sont deja dans le PATH.
FFMPEG_BINARY=
FFPROBE_BINARY=

# Agent IA Performance
# OpenRouter est utilise en priorite pour le developpement avec des modeles gratuits.
# Le service essaie les modeles gratuits avec OPENROUTER_API_KEY_1, puis KEY_2, puis KEY_3.
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_APP_NAME=e-Mall Backend
OPENROUTER_SITE_URL=http://localhost:8000

# 5 modeles gratuits par defaut. Ajuster depuis https://openrouter.ai/models?pricing=free si un slug change.
OPENROUTER_FREE_MODELS=openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,deepseek/deepseek-r1:free,qwen/qwen3-coder:free,openrouter/free

# Providers premium optionnels pour les taches complexes.
# Si absent, limite ou epuise, le service bascule sur les modeles gratuits OpenRouter.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_VERSION=2023-06-01

AI_AGENT_TIMEOUT_SECONDS=45

# Stripe (phase paiement abonnement, a brancher apres le moteur interne).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
